# ── Local Development Brand Override ────────────────────────────────────────
# Force a specific brand in local dev without needing a real domain.
# Options: euro | ok | my | (any brand id from lib/brands.ts)
NEXT_PUBLIC_BRAND=euro

# ── Production ───────────────────────────────────────────────────────────────
# In production, leave NEXT_PUBLIC_BRAND unset.
# The middleware reads the real hostname and resolves the brand automatically.
